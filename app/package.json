    "@tailwindcss/vite": "^4.3.0",
    "daisyui": "^5.5.23",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
